#!/usr/bin/env zsh
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

AGENT_ENV_FILE="${JARVIS_AGENT_ENV_FILE:-$HOME/.secrets/jarvis-agent.env}"
AGENT_ENV_LOADED="0"
if [[ -f "$AGENT_ENV_FILE" ]]; then
  set -a
  source "$AGENT_ENV_FILE"
  set +a
  AGENT_ENV_LOADED="1"
fi

TASK="${*:-}"
if [[ -z "$TASK" ]]; then
  echo "usage: jarvis-agent-pipeline '<task text>'" >&2
  exit 2
fi

redact_sensitive_text() {
  JARVIS_REDACT_INPUT="$1" python3 - <<'PY'
import os, re

text = os.environ.get("JARVIS_REDACT_INPUT", "")
patterns = [
    r"sk-proj-[A-Za-z0-9_-]{20,}",
    r"sk-[A-Za-z0-9_-]{20,}",
    r"gh[pousr]_[A-Za-z0-9_]{20,}",
    r"xox[baprs]-[A-Za-z0-9-]{20,}",
    r"AIza[0-9A-Za-z_-]{20,}",
    r"AKIA[0-9A-Z]{16}",
    r"(?is)-----BEGIN [A-Z ]*PRIVATE KEY-----.*?-----END [A-Z ]*PRIVATE KEY-----",
    r"(?i)\b(api[_ -]?key|token|secret|password|passwd|锌邪褉芯谢褜|褋械泻褉械褌)\s*[:=]\s*['\"]?[^'\"\s]{8,}",
]
for pattern in patterns:
    text = re.sub(pattern, "[REDACTED_SECRET]", text)
print(text, end="")
PY
}

TASK_REDACTED="$(redact_sensitive_text "$TASK")"
TASK_HAS_SECRET="0"
if [[ "$TASK_REDACTED" != "$TASK" ]]; then
  TASK_HAS_SECRET="1"
fi

PROJECT_DIR="${JARVIS_PROJECT_DIR:-/Users/pirajoke/jarvis}"
PROJECT_NAME="${JARVIS_PROJECT_NAME:-${PROJECT_DIR:t}}"
REPORT_DIR="${JARVIS_AGENT_REPORT_DIR:-$HOME/Library/Logs/jarvis-agent-pipeline}"
RUN_ID="${JARVIS_AGENT_RUN_ID:-$(date '+%Y%m%d-%H%M%S')}"
REPORT="$REPORT_DIR/$RUN_ID.md"
PIXEL_EVENT="$HOME/scripts/jarvis-pixel-agent-event"
PIXEL_CLEANUP="$HOME/scripts/jarvis-pixel-agent-cleanup"
OMNI_APPROVAL_ENABLED="${JARVIS_OMNI_APPROVAL_ENABLED:-1}"
OMNI_APPROVAL_LEDGER="${JARVIS_OMNI_APPROVAL_LEDGER:-$HOME/omniharness/.omniharness/jarvis-approval-ledger.jsonl}"
SELF_HEAL_ENABLED="${JARVIS_AGENT_SELF_HEAL_ENABLED:-1}"
SELF_HEAL_MAX_RETRIES="${JARVIS_AGENT_SELF_HEAL_MAX_RETRIES:-1}"
SELF_LEARNING_LEDGER="${JARVIS_AGENT_SELF_LEARNING_LEDGER:-$HOME/omniharness/.omniharness/jarvis-self-learning.jsonl}"
AGENT_PROVIDER="${JARVIS_AGENT_PROVIDER:-auto}"
AGENT_BUDGET="${JARVIS_AGENT_BUDGET:-normal}"
AGENT_BUDGET="${AGENT_BUDGET:l}"
case "$AGENT_BUDGET" in
  cheap|normal|deep) ;;
  *) AGENT_BUDGET="normal" ;;
esac
CODEX_BIN="${JARVIS_CODEX_BIN:-/Applications/Codex.app/Contents/Resources/codex}"
CODEX_MODEL="${JARVIS_CODEX_MODEL:-}"
CODEX_REASONING_EFFORT="${JARVIS_CODEX_REASONING_EFFORT:-low}"
CODEX_APPROVAL_POLICY="${JARVIS_CODEX_APPROVAL_POLICY:-never}"

SUPERVISOR_PERMISSION="${JARVIS_SUPERVISOR_PERMISSION:-dontAsk}"
BUILDER_PERMISSION="${JARVIS_BUILDER_PERMISSION:-auto}"
TESTER_PERMISSION="${JARVIS_TESTER_PERMISSION:-auto}"
MODEL="${JARVIS_AGENT_MODEL:-sonnet}"
TASK_MODE_HINT="normal"
if print -r -- "$TASK" | grep -Eiq '薪械 屑械薪褟泄 褎邪泄谢褘|do not (edit|change) files|no files|read-only|smoke|ack only'; then
  TASK_MODE_HINT="read_only_smoke: use only the literal user task, do not infer unrelated backlog work, do not propose or make file changes, Builder should ACK only, Tester should verify logically."
fi
BUDGET_POLICY=""
BUDGET_ENVELOPE=""
case "$AGENT_BUDGET" in
  cheap)
    BUDGET_POLICY="Cheap mode: minimize model calls and context. Prefer status/plan/read-only answers. Do not do broad repo/vault searches. Do not edit files unless the user explicitly asked for a small fix. Keep each role concise and stop with a clear next step instead of expanding scope."
    BUDGET_ENVELOPE="5k-30k rough target; no self-heal retries unless explicitly enabled"
    if [[ -z "${JARVIS_AGENT_SELF_HEAL_MAX_RETRIES:-}" ]]; then
      SELF_HEAL_MAX_RETRIES="0"
    fi
    ;;
  deep)
    BUDGET_POLICY="Deep mode: allowed to inspect broader context, implement a scoped fix, run verification, and include evidence. Still avoid unrelated backlog and stop after one complete Supervisor -> Builder -> Tester loop with a concrete report."
    BUDGET_ENVELOPE="80k-300k+ rough target; broader context and up to two self-heal retries"
    if [[ -z "${JARVIS_AGENT_SELF_HEAL_MAX_RETRIES:-}" ]]; then
      SELF_HEAL_MAX_RETRIES="2"
    fi
    ;;
  *)
    BUDGET_POLICY="Normal mode: use enough context for the explicit task, keep changes scoped, run relevant checks, and avoid broad unrelated exploration."
    BUDGET_ENVELOPE="20k-80k rough target; scoped context and one self-heal retry"
    ;;
esac

mkdir -p "$REPORT_DIR"

omni_risk_level() {
  local text="${1:l}"
  if print -r -- "$text" | grep -Eiq 'rm -rf|drop database|delete database|truncate table|order_send|payment|wire transfer|private key|secret key|api key|锌邪褉芯谢|褋械泻褉械褌|锌褉懈胁邪褌薪|褍写邪谢懈 斜邪蟹|褋薪械褋褌懈|褎芯褉屑邪褌懈褉'; then
    echo "high"
    return 0
  fi
  echo "normal"
}

omni_allowed_tools_for_role() {
  local role="$1"
  local risk="$2"
  if [[ "$OMNI_APPROVAL_ENABLED" != "1" || "$risk" == "high" || "$TASK_MODE_HINT" == read_only_smoke:* ]]; then
    echo ""
    return 0
  fi
  case "$role" in
    builder)
      echo "Read Grep Glob LS Edit MultiEdit Write Bash(git status*) Bash(git diff*) Bash(git add*) Bash(git commit*) Bash(git push*) Bash(python3 -m pytest*) Bash(pytest*) Bash(python3 -m py_compile*) Bash(zsh -n*) Bash(./scripts/deploy_macmini.sh*)"
      ;;
    tester)
      echo "Read Grep Glob LS Bash(git status*) Bash(git diff*) Bash(python3 -m pytest*) Bash(pytest*) Bash(python3 -m py_compile*) Bash(zsh -n*) Bash(launchctl print*) Bash(curl -s*)"
      ;;
    *)
      echo ""
      ;;
  esac
}

omni_resolved_permission() {
  local role="$1"
  local requested="$2"
  local risk="$3"
  if [[ "$OMNI_APPROVAL_ENABLED" != "1" || "$TASK_MODE_HINT" == read_only_smoke:* ]]; then
    echo "$requested"
    return 0
  fi
  if [[ "$risk" == "high" ]]; then
    echo "dontAsk"
    return 0
  fi
  case "$role" in
    supervisor) echo "dontAsk" ;;
    builder|tester) echo "auto" ;;
    *) echo "$requested" ;;
  esac
}

omni_audit() {
  local role="$1"
  local requested="$2"
  local resolved="$3"
  local risk="$4"
  local tools="$5"
  local decision="auto"
  local reason="safe project-scoped Jarvis pipeline action"
  if [[ "$risk" == "high" ]]; then
    decision="manual"
    reason="high-risk operation requires explicit human approval"
  elif [[ "$TASK_MODE_HINT" == read_only_smoke:* ]]; then
    decision="read_only"
    reason="read-only smoke task"
  elif [[ "$role" == "supervisor" ]]; then
    decision="read_only"
    reason="Supervisor only plans and checks acceptance criteria"
  fi

  mkdir -p "${OMNI_APPROVAL_LEDGER:h}"
  JARVIS_OMNI_AUDIT_ROLE="$role" \
  JARVIS_OMNI_AUDIT_REQUESTED="$requested" \
  JARVIS_OMNI_AUDIT_RESOLVED="$resolved" \
  JARVIS_OMNI_AUDIT_RISK="$risk" \
  JARVIS_OMNI_AUDIT_TOOLS="$tools" \
  JARVIS_OMNI_AUDIT_DECISION="$decision" \
  JARVIS_OMNI_AUDIT_REASON="$reason" \
  JARVIS_OMNI_AUDIT_RUN="$RUN_ID" \
  JARVIS_OMNI_AUDIT_PROJECT="$PROJECT_DIR" \
  JARVIS_OMNI_AUDIT_TASK="$TASK_REDACTED" \
  python3 - <<'PY' >> "$OMNI_APPROVAL_LEDGER" 2>/dev/null || true
import json, os
from datetime import datetime, timezone

keys = {
    "run_id": "JARVIS_OMNI_AUDIT_RUN",
    "role": "JARVIS_OMNI_AUDIT_ROLE",
    "project": "JARVIS_OMNI_AUDIT_PROJECT",
    "task": "JARVIS_OMNI_AUDIT_TASK",
    "requested_permission": "JARVIS_OMNI_AUDIT_REQUESTED",
    "resolved_permission": "JARVIS_OMNI_AUDIT_RESOLVED",
    "risk": "JARVIS_OMNI_AUDIT_RISK",
    "decision": "JARVIS_OMNI_AUDIT_DECISION",
    "reason": "JARVIS_OMNI_AUDIT_REASON",
    "allowed_tools": "JARVIS_OMNI_AUDIT_TOOLS",
}
event = {"ts": datetime.now(timezone.utc).isoformat()}
event.update({out: os.environ.get(env, "") for out, env in keys.items()})
print(json.dumps(event, ensure_ascii=False))
PY
}

pixel_event() {
  if [[ ! -x "$PIXEL_EVENT" ]]; then
    return 0
  fi
  local event_command="${1:-}"
  local event_role="${2:-}"
  local event_message="${3:-}"
  local event_phase="${4:-}"
  local event_handoff="${5:-}"
  local event_evidence="${6:-}"

  JARVIS_PIXEL_PROJECT_NAME="$PROJECT_NAME" \
    JARVIS_PIXEL_PROJECT_DIR="$PROJECT_DIR" \
    JARVIS_PIXEL_TASK="$TASK_REDACTED" \
    JARVIS_PIXEL_PHASE="$event_phase" \
    JARVIS_PIXEL_HANDOFF="$event_handoff" \
    JARVIS_PIXEL_REPORT="$REPORT" \
    JARVIS_PIXEL_EVIDENCE="$event_evidence" \
    "$PIXEL_EVENT" "$event_command" "$event_role" "$event_message" >/dev/null 2>&1 || true
}

pixel_cleanup() {
  if [[ ! -x "$PIXEL_CLEANUP" ]]; then
    return 0
  fi
  "$PIXEL_CLEANUP" >/dev/null 2>&1 || true
}

trap pixel_cleanup EXIT

pixel_cleanup
pixel_event spawn supervisor "online" "Ready to turn Max requests into acceptance criteria" "Builder"
pixel_event spawn builder "online" "Ready to implement scoped Jarvis tasks" "Tester"
pixel_event spawn tester "online" "Ready to verify Builder output" "Supervisor"

run_claude_role() {
  local role="$1"
  local permission="$2"
  local system_prompt="$3"
  local user_prompt="$4"
  local output=""
  local code=0
  local risk=""
  local resolved_permission=""
  local allowed_tools=""
  local -a claude_cmd

  cd "$PROJECT_DIR"
  risk="$(omni_risk_level "$TASK $user_prompt")"
  resolved_permission="$(omni_resolved_permission "$role" "$permission" "$risk")"
  allowed_tools="$(omni_allowed_tools_for_role "$role" "$risk")"
  omni_audit "$role" "$permission" "$resolved_permission" "$risk" "$allowed_tools"

  claude_cmd=(claude -p
    --model "$MODEL"
    --name "jarvis-${role}-${RUN_ID}"
    --permission-mode "$resolved_permission"
    --output-format text
    --append-system-prompt "$system_prompt")
  if [[ -n "$allowed_tools" ]]; then
    claude_cmd+=(--allowedTools "$allowed_tools")
  fi

  set +e
  output="$(print -r -- "$user_prompt" | "${claude_cmd[@]}" 2>&1)"
  code=$?
  set -e

  if (( code != 0 )); then
    {
      echo "ROLE_FAILED=$role"
      echo "EXIT_CODE=$code"
      echo
      print -r -- "$output"
    }
    return "$code"
  fi

  print -r -- "$output"
}

codex_sandbox_for_role() {
  local role="$1"
  local risk="$2"
  if [[ "$risk" == "high" || "$TASK_MODE_HINT" == read_only_smoke:* ]]; then
    echo "read-only"
    return 0
  fi
  case "$role" in
    builder) echo "workspace-write" ;;
    *) echo "read-only" ;;
  esac
}

run_codex_role() {
  local role="$1"
  local permission="$2"
  local system_prompt="$3"
  local user_prompt="$4"
  local output=""
  local final_output=""
  local code=0
  local risk=""
  local sandbox=""
  local final_file=""
  local -a codex_cmd

  cd "$PROJECT_DIR"
  if [[ ! -x "$CODEX_BIN" ]]; then
    echo "ROLE_FAILED=$role"
    echo "PROVIDER_FAILED=codex"
    echo "EXIT_CODE=127"
    echo
    echo "Codex binary is not executable: $CODEX_BIN"
    return 127
  fi

  risk="$(omni_risk_level "$TASK $user_prompt")"
  sandbox="$(codex_sandbox_for_role "$role" "$risk")"
  omni_audit "$role" "codex:$sandbox" "codex:$sandbox" "$risk" "codex exec --sandbox $sandbox --approval $CODEX_APPROVAL_POLICY"

  final_file="$REPORT_DIR/$RUN_ID.$role.codex.final.txt"
  rm -f "$final_file" 2>/dev/null || true

  codex_cmd=("$CODEX_BIN" exec
    --cd "$PROJECT_DIR"
    --sandbox "$sandbox"
    --skip-git-repo-check
    -c "approval_policy=\"$CODEX_APPROVAL_POLICY\""
    -c "model_reasoning_effort=\"$CODEX_REASONING_EFFORT\""
    -c 'model_verbosity="low"'
    --output-last-message "$final_file")
  if [[ -n "$CODEX_MODEL" ]]; then
    codex_cmd+=(-m "$CODEX_MODEL")
  fi

  set +e
  output="$(print -r -- "$system_prompt\n\n$user_prompt" | "${codex_cmd[@]}" - 2>&1)"
  code=$?
  set -e

  if [[ -f "$final_file" ]]; then
    final_output="$(cat "$final_file" 2>/dev/null || true)"
  fi
  if [[ -z "$final_output" ]]; then
    final_output="$output"
  fi

  if (( code != 0 )); then
    {
      echo "ROLE_FAILED=$role"
      echo "PROVIDER_FAILED=codex"
      echo "EXIT_CODE=$code"
      echo
      print -r -- "$output"
    }
    return "$code"
  fi

  echo "Provider: codex"
  echo "Sandbox: $sandbox"
  if [[ -n "$CODEX_MODEL" ]]; then
    echo "Codex model: $CODEX_MODEL"
  fi
  echo
  print -r -- "$final_output"
}

run_agent_role() {
  local role="$1"
  local permission="$2"
  local system_prompt="$3"
  local user_prompt="$4"
  local provider="${AGENT_PROVIDER:l}"
  local output=""
  local codex_output=""
  local diagnosis=""

  case "$provider" in
    claude)
      run_claude_role "$role" "$permission" "$system_prompt" "$user_prompt"
      return $?
      ;;
    codex)
      run_codex_role "$role" "$permission" "$system_prompt" "$user_prompt"
      return $?
      ;;
    auto|"")
      output="$(run_claude_role "$role" "$permission" "$system_prompt" "$user_prompt" || true)"
      if ! role_output_failed "$output"; then
        print -r -- "$output"
        return 0
      fi

      diagnosis="$(classify_role_failure "$output")"
      append_section "Provider Fallback" "- Role: $role
- Primary provider: claude
- Diagnosis: $diagnosis
- Fallback provider: codex
- Codex sandbox: $(codex_sandbox_for_role "$role" "$(omni_risk_level "$TASK $user_prompt")")"
      record_self_learning "$role" "claude_$diagnosis" "fallback_to_codex" "$(print -r -- "$output" | tail -60)"
      pixel_event start "$role" "Claude failed ($diagnosis); trying Codex" "Provider fallback" "Codex returns result or explicit blocker"

      codex_output="$(run_codex_role "$role" "$permission" "$system_prompt" "$user_prompt" || true)"
      if role_output_failed "$codex_output"; then
        {
          print -r -- "$output"
          echo
          echo "--- CODEX FALLBACK ---"
          print -r -- "$codex_output"
        }
        return 1
      fi

      record_self_learning "$role" "claude_$diagnosis" "codex_recovered" "$codex_output"
      echo "Provider fallback: claude -> codex"
      echo
      print -r -- "$codex_output"
      return 0
      ;;
    *)
      echo "ROLE_FAILED=$role"
      echo "EXIT_CODE=2"
      echo
      echo "Unknown JARVIS_AGENT_PROVIDER: $AGENT_PROVIDER. Use auto, claude, or codex."
      return 2
      ;;
  esac
}

role_output_failed() {
  local output="$1"
  print -r -- "$output" | grep -q '^ROLE_FAILED='
}

classify_role_failure() {
  local text="${1:l}"
  if print -r -- "$text" | grep -Eiq 'input must be provided either through stdin|as a prompt argument'; then
    echo "cli_prompt_missing"
    return 0
  fi
  if print -r -- "$text" | grep -Eiq 'out of extra usage|usage limit|rate limit'; then
    echo "usage_limit"
    return 0
  fi
  if print -r -- "$text" | grep -Eiq 'auth|login|required credentials|authentication'; then
    echo "auth_required"
    return 0
  fi
  if print -r -- "$text" | grep -Eiq 'permission|approval|not allowed|denied'; then
    echo "manual_approval_required"
    return 0
  fi
  echo "unknown_retryable"
}

record_self_learning() {
  local role="$1"
  local diagnosis="$2"
  local outcome="$3"
  local detail="$4"

  mkdir -p "${SELF_LEARNING_LEDGER:h}"
  JARVIS_LEARN_RUN="$RUN_ID" \
  JARVIS_LEARN_ROLE="$role" \
  JARVIS_LEARN_PROJECT="$PROJECT_DIR" \
  JARVIS_LEARN_TASK="$TASK" \
  JARVIS_LEARN_DIAGNOSIS="$diagnosis" \
  JARVIS_LEARN_OUTCOME="$outcome" \
  JARVIS_LEARN_DETAIL="$detail" \
  python3 - <<'PY' >> "$SELF_LEARNING_LEDGER" 2>/dev/null || true
import json, os
from datetime import datetime, timezone

event = {
    "ts": datetime.now(timezone.utc).isoformat(),
    "run_id": os.environ.get("JARVIS_LEARN_RUN", ""),
    "role": os.environ.get("JARVIS_LEARN_ROLE", ""),
    "project": os.environ.get("JARVIS_LEARN_PROJECT", ""),
    "task": os.environ.get("JARVIS_LEARN_TASK", ""),
    "diagnosis": os.environ.get("JARVIS_LEARN_DIAGNOSIS", ""),
    "outcome": os.environ.get("JARVIS_LEARN_OUTCOME", ""),
    "detail": os.environ.get("JARVIS_LEARN_DETAIL", "")[:1000],
}
print(json.dumps(event, ensure_ascii=False))
PY
}

attempt_role_self_heal() {
  local role="$1"
  local permission="$2"
  local system_prompt="$3"
  local user_prompt="$4"
  local failed_output="$5"
  local diagnosis=""
  local retry_output=""
  local retry_system=""
  local retry_prompt=""
  local can_retry="1"
  local failure_tail=""

  diagnosis="$(classify_role_failure "$failed_output")"
  failure_tail="$(print -r -- "$failed_output" | tail -60)"
  record_self_learning "$role" "$diagnosis" "detected" "$failure_tail"

  case "$diagnosis" in
    usage_limit|auth_required|manual_approval_required)
      can_retry="0"
      ;;
  esac

  append_section "Self-Healing" "- Role: $role
- Diagnosis: $diagnosis
- Action: $([[ "$SELF_HEAL_ENABLED" == "1" && "$can_retry" == "1" && "$SELF_HEAL_MAX_RETRIES" -gt 0 ]] && echo "retry_once" || echo "stop_and_report")
- Learning ledger: $SELF_LEARNING_LEDGER"

  if [[ "$SELF_HEAL_ENABLED" != "1" || "$can_retry" != "1" || "$SELF_HEAL_MAX_RETRIES" -lt 1 ]]; then
    record_self_learning "$role" "$diagnosis" "not_retried" "$failure_tail"
    print -r -- "$failed_output"
    return 1
  fi

  pixel_event start "$role" "Self-healing retry: $diagnosis" "Recovering from a known pipeline failure" "Return clean result or explicit blocker"

  retry_system="$system_prompt

Self-healing mode. Previous $role attempt failed before producing a useful result. Do not repeat the failure. If you cannot proceed safely, return NEEDS_REPAIR with exact reason and command/evidence needed. Keep the answer concise."
  retry_prompt="Self-healing retry for role: $role

Original user task:
$TASK

Previous failure:
$failure_tail

Original role prompt:
$user_prompt"

  retry_output="$(run_agent_role "$role" "$permission" "$retry_system" "$retry_prompt" || true)"
  append_section "$role Self-Heal Retry" "$retry_output"

  if role_output_failed "$retry_output"; then
    record_self_learning "$role" "$diagnosis" "retry_failed" "$(print -r -- "$retry_output" | tail -60)"
    print -r -- "$retry_output"
    return 1
  fi

  record_self_learning "$role" "$diagnosis" "recovered" "$retry_output"
  append_section "$role" "$retry_output"
  print -r -- "$retry_output"
}

