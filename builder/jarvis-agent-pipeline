append_role_failure_result() {
  local role="$1"
  local output="$2"
  local diagnosis=""
  diagnosis="$(classify_role_failure "$output")"
  case "$diagnosis" in
    usage_limit)
      append_result "blocked_usage_limit" "$role blocked by Claude usage limit"
      echo "blocked by Claude usage limit in $role"
      echo "report $REPORT"
      exit 0
      ;;
    auth_required)
      append_result "blocked_auth" "$role blocked by Claude auth"
      echo "blocked by Claude auth in $role"
      echo "report $REPORT"
      exit 0
      ;;
    manual_approval_required)
      append_result "needs_approval" "$role needs manual approval"
      echo "needs approval in $role"
      echo "report $REPORT"
      exit 0
      ;;
    *)
      append_result "failed" "$role failed"
      echo "failed in $role"
      echo "report $REPORT"
      return 1
      ;;
  esac
}

append_section() {
  local title="$1"
  local body="$2"

  {
    echo
    echo "## $title"
    echo
    print -r -- "$body"
  } >> "$REPORT"
}

append_result() {
  local result_status="$1"
  local detail="${2:-}"
  {
    echo
    echo "## Result"
    echo
    echo "- Status: $result_status"
    echo "- Completed: $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    if [[ -n "$detail" ]]; then
      echo "- Detail: $detail"
    fi
  } >> "$REPORT"
}

