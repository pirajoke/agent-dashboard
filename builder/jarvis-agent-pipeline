#!/usr/bin/env zsh
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

TASK="${*:-}"
if [[ -z "$TASK" ]]; then
  echo "usage: jarvis-agent-pipeline '<task text>'" >&2
  exit 2
fi

PROJECT_DIR="${JARVIS_PROJECT_DIR:-/Users/pirajoke/jarvis}"
PROJECT_NAME="${JARVIS_PROJECT_NAME:-${PROJECT_DIR:t}}"
REPORT_DIR="${JARVIS_AGENT_REPORT_DIR:-$HOME/Library/Logs/jarvis-agent-pipeline}"
RUN_ID="${JARVIS_AGENT_RUN_ID:-$(date '+%Y%m%d-%H%M%S')}"
REPORT="$REPORT_DIR/$RUN_ID.md"
PIXEL_EVENT="$HOME/scripts/jarvis-pixel-agent-event"
PIXEL_CLEANUP="$HOME/scripts/jarvis-pixel-agent-cleanup"

SUPERVISOR_PERMISSION="${JARVIS_SUPERVISOR_PERMISSION:-dontAsk}"
BUILDER_PERMISSION="${JARVIS_BUILDER_PERMISSION:-auto}"
TESTER_PERMISSION="${JARVIS_TESTER_PERMISSION:-auto}"
MODEL="${JARVIS_AGENT_MODEL:-sonnet}"
TASK_MODE_HINT="normal"
if print -r -- "$TASK" | grep -Eiq 'не меняй файлы|do not (edit|change) files|no files|read-only|smoke|ack only'; then
  TASK_MODE_HINT="read_only_smoke: use only the literal user task, do not infer unrelated backlog work, do not propose or make file changes, Builder should ACK only, Tester should verify logically."
fi

mkdir -p "$REPORT_DIR"

pixel_event() {
  if [[ ! -x "$PIXEL_EVENT" ]]; then
    return 0
  fi
  local event_command="${1:-}"
  local event_role="${2:-}"
  local event_message="${3:-}"
  local event_phase="${4:-}"
  local event_handoff="${5:-}"
  local event_evidence="${6:-}"

  JARVIS_PIXEL_PROJECT_NAME="$PROJECT_NAME" \
    JARVIS_PIXEL_PROJECT_DIR="$PROJECT_DIR" \
    JARVIS_PIXEL_TASK="$TASK" \
    JARVIS_PIXEL_PHASE="$event_phase" \
    JARVIS_PIXEL_HANDOFF="$event_handoff" \
    JARVIS_PIXEL_REPORT="$REPORT" \
    JARVIS_PIXEL_EVIDENCE="$event_evidence" \
    "$PIXEL_EVENT" "$event_command" "$event_role" "$event_message" >/dev/null 2>&1 || true
}

pixel_cleanup() {
  if [[ ! -x "$PIXEL_CLEANUP" ]]; then
    return 0
  fi
  "$PIXEL_CLEANUP" >/dev/null 2>&1 || true
}

trap pixel_cleanup EXIT

pixel_cleanup
pixel_event spawn supervisor "online" "Ready to turn Max requests into acceptance criteria" "Builder"
pixel_event spawn builder "online" "Ready to implement scoped Jarvis tasks" "Tester"
pixel_event spawn tester "online" "Ready to verify Builder output" "Supervisor"

run_claude_role() {
  local role="$1"
  local permission="$2"
  local system_prompt="$3"
  local user_prompt="$4"
  local output=""
  local code=0

  cd "$PROJECT_DIR"

  set +e
  output="$(claude -p \
    --model "$MODEL" \
    --name "jarvis-${role}-${RUN_ID}" \
    --permission-mode "$permission" \
    --output-format text \
    --append-system-prompt "$system_prompt" \
    "$user_prompt" 2>&1)"
  code=$?
  set -e

  if (( code != 0 )); then
    {
      echo "ROLE_FAILED=$role"
      echo "EXIT_CODE=$code"
      echo
      print -r -- "$output"
    }
    return "$code"
  fi

  print -r -- "$output"
}

append_section() {
  local title="$1"
  local body="$2"

  {
    echo
    echo "## $title"
    echo
    print -r -- "$body"
  } >> "$REPORT"
}

append_result() {
  local result_status="$1"
  local detail="${2:-}"
  {
    echo
    echo "## Result"
    echo
    echo "- Status: $result_status"
    echo "- Completed: $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    if [[ -n "$detail" ]]; then
      echo "- Detail: $detail"
    fi
  } >> "$REPORT"
}

cat > "$REPORT" <<EOF
# Jarvis Agent Pipeline

- Run: $RUN_ID
- Project: $PROJECT_DIR
- Model: $MODEL
- Task: $TASK
- Task mode: $TASK_MODE_HINT
- Route: Supervisor -> Builder -> Tester
- Permissions:
  - Supervisor: $SUPERVISOR_PERMISSION
  - Builder: $BUILDER_PERMISSION
  - Tester: $TESTER_PERMISSION

EOF

SUPERVISOR_SYSTEM="Ты JARVIS Supervisor. Ты не меняешь файлы. Твоя задача: понять буквальную задачу пользователя, разложить её на Builder/Tester handoff, определить риски, критерии готовности и короткий следующий шаг. Не подменяй задачу старым backlog-контекстом. Task mode: $TASK_MODE_HINT. Пиши по-русски, кратко, структурно."
SUPERVISOR_PROMPT="Задача пользователя: $TASK
Task mode: $TASK_MODE_HINT

Верни:
1. Цель
2. Builder handoff
3. Tester handoff
4. Риски
5. Критерии готовности"

pixel_event start supervisor "Request: $TASK" "Defining acceptance criteria and routing plan" "Builder receives scope, risks, and checks"
SUPERVISOR_OUTPUT="$(run_claude_role supervisor "$SUPERVISOR_PERMISSION" "$SUPERVISOR_SYSTEM" "$SUPERVISOR_PROMPT" || true)"
append_section "Supervisor" "$SUPERVISOR_OUTPUT"
pixel_event done supervisor "Acceptance criteria ready for Builder" "Handoff ready" "Builder receives Supervisor section from report" "Report: $REPORT"

if print -r -- "$SUPERVISOR_OUTPUT" | grep -q '^ROLE_FAILED='; then
  pixel_event permission supervisor "failed"
  append_result "failed" "Supervisor failed"
  echo "failed in Supervisor"
  echo "report $REPORT"
  exit 3
fi

BUILDER_SYSTEM="Ты JARVIS Builder. Ты работаешь в проекте $PROJECT_DIR. Если permission-mode не позволяет менять файлы или запускать команды, не зависай и не проси пользователя: верни NEEDS_APPROVAL с точным действием. Если задача явно dry-run/read-only/smoke/ACK only, не меняй файлы, не запускай команды, верни ACK и handoff для Tester. Не подменяй задачу старым backlog-контекстом. Task mode: $TASK_MODE_HINT. Пиши по-русски, кратко, с файлами и командами проверки."
BUILDER_PROMPT="Оригинальная задача:
$TASK
Task mode:
$TASK_MODE_HINT

Supervisor handoff:
$SUPERVISOR_OUTPUT

Сделай Builder-часть. Верни:
1. Что сделано или что нужно сделать
2. Изменённые файлы, если были
3. Команды проверки, если нужны
4. Handoff для Tester"

pixel_event start builder "Build/check: $TASK" "Reading context and producing implementation handoff" "Tester receives files, commands, and result"
BUILDER_OUTPUT="$(run_claude_role builder "$BUILDER_PERMISSION" "$BUILDER_SYSTEM" "$BUILDER_PROMPT" || true)"
append_section "Builder" "$BUILDER_OUTPUT"
pixel_event done builder "Builder result ready for Tester" "Implementation/check complete" "Tester receives Builder section from report" "Report: $REPORT"

if print -r -- "$BUILDER_OUTPUT" | grep -q '^ROLE_FAILED='; then
  pixel_event permission builder "failed"
  append_result "failed" "Builder failed"
  echo "failed in Builder"
  echo "report $REPORT"
  exit 4
fi

TESTER_SYSTEM="Ты JARVIS Tester. Ты проверяешь результат Builder. Если permission-mode не позволяет запускать команды, не зависай и не проси пользователя: верни NEEDS_APPROVAL с точной командой. Если задача read-only/dry-run/smoke/ACK only, проверяй логически и не запускай команды. Не подменяй задачу старым backlog-контекстом. Task mode: $TASK_MODE_HINT. Пиши PASS/FAIL, что проверено, риски и следующий шаг."
TESTER_PROMPT="Оригинальная задача:
$TASK
Task mode:
$TASK_MODE_HINT

Supervisor output:
$SUPERVISOR_OUTPUT

Builder output:
$BUILDER_OUTPUT

Проверь итог. Верни:
1. PASS или FAIL
2. Что проверено
3. Остаточные риски
4. Следующий шаг"

pixel_event start tester "Verify: $TASK" "Checking request vs result and evidence" "Supervisor receives pass/fail verdict"
TESTER_OUTPUT="$(run_claude_role tester "$TESTER_PERMISSION" "$TESTER_SYSTEM" "$TESTER_PROMPT" || true)"
append_section "Tester" "$TESTER_OUTPUT"
pixel_event done tester "Tester verdict ready" "Verification complete" "Supervisor receives Tester section from report" "Report: $REPORT"

if print -r -- "$TESTER_OUTPUT" | grep -q '^ROLE_FAILED='; then
  pixel_event permission tester "failed"
  append_result "failed" "Tester failed"
  echo "failed in Tester"
  echo "report $REPORT"
  exit 5
fi

append_result "done" "Route complete"

echo "report $REPORT"
echo "route Supervisor -> Builder -> Tester"
echo "done"
