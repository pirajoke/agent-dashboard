  local output="${1:l}"
  print -r -- "$output" | grep -Eiq '(^|[[:space:]])needs_input([[:space:][:punct:]]|$)|(^|[[:space:]])need(s)? input([[:space:][:punct:]]|$)|^[[:space:]>#*-]*(薪械褌 褟胁薪芯泄 蟹邪写邪褔懈|薪械褌 泻芯薪泻褉械褌薪芯泄 蟹邪写邪褔懈|薪褍卸薪邪 泻芯薪泻褉械褌薪邪褟 蟹邪写邪褔邪|褋泻邪卸懈, 褔褌芯 泻芯薪泻褉械褌薪芯|褔褌芯 泻芯薪泻褉械褌薪芯 褏芯褔械褕褜|薪褍卸薪芯 褍褌芯褔薪懈褌褜|褍褌芯褔薪懈 蟹邪写邪褔褍)'
