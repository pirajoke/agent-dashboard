import json
import os
import re
import sqlite3
from datetime import datetime, timezone
from pathlib import Path


def now() -> str:
    return datetime.now(timezone.utc).isoformat()


def clean(text: str, limit: int = 900) -> str:
    text = re.sub(r"\s+", " ", text or "").strip()
    if len(text) <= limit:
        return text
    return text[: limit - 1].rstrip() + "…"


def section(report_text: str, title: str) -> str:
    match = re.search(rf"\n## {re.escape(title)}\n\n(.*?)(?=\n## |\Z)", report_text, re.S)
    return clean(match.group(1), 1000) if match else ""


status = os.environ.get("JARVIS_PIPELINE_STATUS", "")
detail = os.environ.get("JARVIS_PIPELINE_DETAIL", "")
run_id = os.environ.get("JARVIS_PIPELINE_RUN_ID", "")
report_path = os.environ.get("JARVIS_PIPELINE_REPORT", "")
project_name = os.environ.get("JARVIS_PIPELINE_PROJECT_NAME", "jarvis")
project_dir = os.environ.get("JARVIS_PIPELINE_PROJECT_DIR", "")
task = os.environ.get("JARVIS_PIPELINE_TASK", "")
provider = os.environ.get("JARVIS_PIPELINE_PROVIDER", "")
budget = os.environ.get("JARVIS_PIPELINE_BUDGET", "")
db_path = Path(os.environ.get("JARVIS_PIPELINE_BRIDGE_DB", "~/.agent-bridge/bridge.db")).expanduser()
dashboard_url = os.environ.get("JARVIS_PIPELINE_DASHBOARD_URL", "")

report_text = ""
try:
    report_text = Path(report_path).read_text(encoding="utf-8", errors="replace")
except OSError:
    report_text = ""

tester = section(report_text, "Tester") or section(report_text, "Tester Self-Heal Retry")
builder = section(report_text, "Builder") or section(report_text, "Builder Self-Heal Retry")
supervisor = section(report_text, "Supervisor") or section(report_text, "Supervisor Self-Heal Retry")

bridge_status = "done"
if status.startswith("blocked_") or status in {"failed", "needs_approval"}:
    bridge_status = "failed"

if status == "done":
    result = "Готово: Agent Pipeline завершил маршрут Supervisor -> Builder -> Tester."
    if tester:
        result += f"\n\nTester: {tester}"
elif status == "needs_input":
    result = f"Нужно уточнить задачу: {detail or 'Supervisor не получил достаточно конкретный запрос.'}"
elif status == "blocked_secret":
    result = "Задача остановлена: в тексте найден похожий на секрет фрагмент. Ключ нужно отозвать/перевыпустить и передавать через env/secret storage."
else:
    result = f"Pipeline остановился со статусом {status}."
    if detail:
        result += f" Деталь: {detail}"
    if tester:
        result += f"\n\nTester: {tester}"
    elif builder:
        result += f"\n\nBuilder: {builder}"

error = "" if bridge_status == "done" else result
metadata = {
    "event": "agent_pipeline_result",
    "triggered_by": "command_center",
    "entrypoint": "command_center.agent_pipeline",
    "assigned_agent": "SUPERVISOR_BUILDER_TESTER",
    "route": "Supervisor -> Builder -> Tester",
    "route_reason": "Command Center pipeline completed a real Jarvis task",
    "project": project_name,
    "project_dir": project_dir,
    "run_id": run_id,
    "report_path": report_path,
    "dashboard_url": dashboard_url,
    "provider": provider,
    "budget": budget,
    "pipeline_status": status,
    "detail": detail,
    "supervisor_preview": supervisor,
    "builder_preview": builder,
    "tester_preview": tester,
}
task_id = "pipeline-" + re.sub(r"[^A-Za-z0-9_.-]", "-", run_id)[:80]
created_at = now()
completed_at = created_at
description = f"Agent Pipeline: {task}" if task else "Agent Pipeline run"

db_path.parent.mkdir(parents=True, exist_ok=True)
conn = sqlite3.connect(str(db_path))
try:
    conn.execute("PRAGMA journal_mode=WAL")
    conn.executescript("""
        CREATE TABLE IF NOT EXISTS tasks (
            id TEXT PRIMARY KEY,
            status TEXT NOT NULL DEFAULT 'pending',
            agent_role TEXT,
            project TEXT,
            description TEXT NOT NULL,
            result TEXT,
            error TEXT,
            callback_url TEXT,
            metadata TEXT,
            created_at TEXT NOT NULL,
            claimed_at TEXT,
            completed_at TEXT
        );
        CREATE INDEX IF NOT EXISTS idx_tasks_status ON tasks(status);
        CREATE TABLE IF NOT EXISTS messages (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            task_id TEXT NOT NULL REFERENCES tasks(id),
            sender TEXT NOT NULL,
            receiver TEXT NOT NULL,
            type TEXT NOT NULL,
            body TEXT NOT NULL,
            metadata TEXT,
            created_at TEXT NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_messages_task ON messages(task_id);
    """)
    existing = conn.execute("SELECT id FROM tasks WHERE id = ?", (task_id,)).fetchone()
    payload = (
        bridge_status,
        "SUPERVISOR_BUILDER_TESTER",
        project_name,
        description,
        result if bridge_status == "done" else None,
        error if bridge_status != "done" else None,
        json.dumps(metadata, ensure_ascii=False, sort_keys=True),
        completed_at,
        task_id,
    )
    if existing:
        conn.execute(
            "UPDATE tasks SET status=?, agent_role=?, project=?, description=?, result=?, error=?, metadata=?, completed_at=? WHERE id=?",
            payload,
        )
    else:
        conn.execute(
            "INSERT INTO tasks (status, agent_role, project, description, result, error, metadata, created_at, completed_at, id) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
            (
                bridge_status,
                "SUPERVISOR_BUILDER_TESTER",
                project_name,
                description,
                result if bridge_status == "done" else None,
                error if bridge_status != "done" else None,
                json.dumps(metadata, ensure_ascii=False, sort_keys=True),
                created_at,
                completed_at,
                task_id,
            ),
        )
    conn.execute(
        "INSERT INTO messages (task_id, sender, receiver, type, body, metadata, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)",
        (
            task_id,
            "AGENT_PIPELINE",
            "JARVIS",
            "result" if bridge_status == "done" else "error",
            result,
            json.dumps(metadata, ensure_ascii=False, sort_keys=True),
            completed_at,
        ),
    )
    conn.commit()
finally:
    conn.close()
PY
}

